# === User-requested high-priority ignores ===
# Deploy / ops scripts (local-only, not committed)
deploy/


# Ignore database files
*.db
*.sqlite
*.sqlite3

# Ignore dotfiles and dot-directories by default
.*
**/.*
**/.*/
.env
# Keep this file trackable
!.gitignore

# === Secrets / credentials ===
.env
.env.*
**/.env
**/.env.*
*.pem
*.key
*.p12
*.pfx
*secret*
*token*
*credential*
*credentials*

# Known sensitive config file in this repo
config/firebase-credentials.json

# === Common generated/cache artifacts ===
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
node_modules/
dist/
build/
.npm-cache/
.playwright-mcp/
*.log
frontend/playwright-report/
frontend/test-results/
frontend/playwright/.cache/

# === Local startup / run scripts (do not commit) ===
start*.sh
start*.bat
run*.sh
run*.bat
dev.sh
dev.bat
deploy.sh
deploy.bat

# Windows reserved filename edge case found in repo
backend/nul
.gitnexus
